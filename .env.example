# PostgreSQL
POSTGRES_USER=lifelog
POSTGRES_PASSWORD=lifelog_dev_password
POSTGRES_DB=lifelog
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# Storage
UPLOAD_DIR=/app/uploads

# Whisper Transcription
# Model sizes: tiny, base, small, medium, large-v3 (larger = more accurate, slower)
WHISPER_MODEL_DIR=/models
WHISPER_DEFAULT_MODEL=base
# Device: auto (detect GPU), cuda, cpu
WHISPER_DEVICE=auto
# Compute type: auto, int8 (fastest CPU), float16 (GPU), float32 (most compatible)
WHISPER_COMPUTE_TYPE=auto
# Max concurrent transcription tasks (1 recommended for CPU, increase with GPU)
TRANSCRIPTION_CONCURRENCY=1
